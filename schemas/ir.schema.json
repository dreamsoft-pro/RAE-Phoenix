{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://feniks.local/schemas/ir.schema.json",
  "title": "Feniks IR Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "entity",
    "location",
    "relations",
    "scores",
    "metadata",
    "migration"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "component",
            "service",
            "directive",
            "filter",
            "route",
            "template",
            "util"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file",
        "span"
      ],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "module": {
          "type": [
            "string",
            "null"
          ]
        },
        "span": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "integer",
              "minimum": 1
            },
            "end": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "relations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calls_functions",
        "ui_routes",
        "api_calls"
      ],
      "properties": {
        "calls_functions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ui_routes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "api_calls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "method",
              "url",
              "confidence",
              "evidence"
            ],
            "properties": {
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "DELETE",
                  "PATCH",
                  "HEAD",
                  "OPTIONS",
                  "UNKNOWN"
                ]
              },
              "url": {
                "type": "string",
                "minLength": 1
              },
              "confidence": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "evidence": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "file",
                  "start",
                  "end",
                  "rule"
                ],
                "properties": {
                  "file": {
                    "type": "string"
                  },
                  "start": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "end": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "rule": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "io_contract": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "api_contract_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cyclomatic_complexity",
        "criticality_score"
      ],
      "properties": {
        "cyclomatic_complexity": {
          "type": "number",
          "minimum": 0
        },
        "criticality_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "business_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary_en": {
          "type": [
            "string",
            "null"
          ]
        },
        "git_last_commit": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "hash",
            "author",
            "date",
            "message"
          ],
          "properties": {
            "hash": {
              "type": "string"
            },
            "author": {
              "type": "string"
            },
            "date": {
              "type": "string"
            },
            "message": {
              "type": "string"
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "file",
              "start",
              "end",
              "rule"
            ],
            "properties": {
              "file": {
                "type": "string"
              },
              "start": {
                "type": "integer",
                "minimum": 1
              },
              "end": {
                "type": "integer",
                "minimum": 1
              },
              "rule": {
                "type": "string"
              }
            }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "rationale"
      ],
      "properties": {
        "target": {
          "type": "string",
          "enum": [
            "ReactComponent",
            "ReactHook",
            "Util",
            "Route",
            "Layout"
          ]
        },
        "rationale": {
          "type": "string"
        }
      }
    }
  }
}