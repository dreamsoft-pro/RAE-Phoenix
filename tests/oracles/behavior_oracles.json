  "User Logs In": {
    "description": "A user logs into the application.",
    "steps": [
      {
        "action": "goto",
        "url": "/pl",
        "description": "Go to the homepage"
      },
      {
        "action": "click",
        "selector": "a[ui-sref='login']",
        "description": "Click on the login link"
      },
      {
        "action": "fill",
        "selector": "input[id='user-email']",
        "value": "office@diditalprint.pro",
        "description": "Fill in the login"
      },
      {
        "action": "fill",
        "selector": "input[name='password']",
        "value": "1234",
        "description": "Fill in the password"
      },
      {
        "action": "click",
        "selector": "button.btn-login",
        "description": "Click the login button"
      },
      {
        "action": "expect",
        "selector": "div.alert-danger",
        "assertion": "hidden",
        "description": "Expect no error message to be visible"
      },
      {
        "action": "wait_for_selector",
        "selector": "a[ui-sref='logout']",
        "description": "Wait for the logout button to appear"
      },
      {
        "action": "expect",
        "selector": "a[ui-sref='logout']",
        "assertion": "visible",
        "description": "Expect the logout button to be visible"
      }
    ]
  }
}