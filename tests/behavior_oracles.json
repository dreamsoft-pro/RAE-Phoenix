[
  {
    "story_name": "User Login",
    "steps": [
      { "action": "goto", 
      "url": "{{BASE_URL}}/pl" },

      { "action": "click", 
      "selector": "a[href=\"/pl/zaloguj-sie\"]" },

      { "action": "wait_for_selector", 
      "selector": "form[ng-submit=\"login(credentials)\"]" },

      { "action": "fill", 
      "selector": "form[ng-submit=\"login(credentials)\"] #user-email", 
      "value": "office@digitalprint.pro" },
      { "action": "fill", 
      "selector": "form[ng-submit=\"login(credentials)\"] #user-password", 
      "value": "1234" },

      { "action": "click", 
      "selector": "form[ng-submit=\"login(credentials)\"] button[type=\"submit\"]" },


      { "action": "wait_for_selector", 
      "selector": "main .orders, main .orders-list, main h1" },


      { "action": "wait_for_url_optional", 
      "url": "{{BASE_URL}}/pl/klient/moja-strefa/zamowienia" },


      { "action": "expect", 
      "selector": "h1", 
      "assertion": "contains_text", "value": "zamówienia" }
    ]
  }
]
