export FENIKS_REPO_ROOT="$PWD"
export FENIKS_FRONTEND_ROOT="$PWD/frontend-master"
export FENIKS_OUT_DIR="$PWD/runs"
export QDRANT_URL="http://localhost:6333"
export QDRANT_API_KEY=""           # jeśli wymagane
export QDRANT_COLLECTION="code_chunks"
export QDRANT_DIM=384
export QDRANT_USE_SPARSE=1
export EMBED_MODEL="sentence-transformers/all-MiniLM-L6-v2"
export EMBED_BATCH_SIZE=64
export EMBED_MAX_CHARS=5000
RAE_AGENT_EMAIL=office@digitalprint.pro
